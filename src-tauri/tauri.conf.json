{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DryerFox",
  "version": "1.0.0",
  "identifier": "com.dougschmidt.dryerfox",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DryerFox",
        "width": 800,
        "height": 850,
        "minWidth": 800,
        "minHeight": 850,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null,
      "freezePrototype": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
